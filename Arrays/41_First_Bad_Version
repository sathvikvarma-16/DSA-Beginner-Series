"""
Problem: First Bad Version
Link: https://leetcode.com/problems/first-bad-version/

Approach:
- Use binary search on versions 1 to n.
- If mid is bad, first bad version is at mid or before mid.
- Otherwise, it must be after mid.
- Continue until left == right.

Time Complexity: O(log n)
Space Complexity: O(1)
"""

# The isBadVersion API is already defined for you.
# def isBadVersion(version):

def firstBadVersion(n):
    left = 1
    right = n

    while left < right:
        mid = left + (right - left) // 2

        # If mid is bad, answer is in left half including mid
        if isBadVersion(mid):
            right = mid
        else:
            # First bad version is in right half
            left = mid + 1

    return left
